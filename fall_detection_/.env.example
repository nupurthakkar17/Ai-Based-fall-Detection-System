# FallGuard AI — Environment Variables
# Copy this file to .env and fill in your values

FLASK_ENV=development
SECRET_KEY=your-very-secret-key-change-this

# Database (SQLite default, uncomment for PostgreSQL)
# DATABASE_URL=postgresql://user:pass@localhost/fallguard

# Email Alerts (Gmail example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=fallguard@yourdomain.com

# Twilio SMS Alerts
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Server
HOST=0.0.0.0
PORT=5000
